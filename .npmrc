# Reduzir ETIMEDOUT no build Docker/Nixpacks/EasyPanel (rede lenta ou instável ao registry npm)
registry=https://registry.npmjs.org/
fetch-timeout=600000
fetch-retries=15
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
# Menos conexões paralelas costuma estabilizar leituras longas em redes ruins
maxsockets=8
